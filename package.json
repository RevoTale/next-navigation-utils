{
	"author": {
		"name": "l-you",
		"email": "l-you@revotale.com",
		"url": "https://github.com/l-you"
	},
	"version": "1.0.4",
	"name": "next-navigation-utils",
	"main": "index.js",
	"license": "MIT",
	"private": false,
	"sideEffects": false,
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./index.d.ts",
			"import": "./index.js",
			"require": "./index.cjs"
		},
		"./client": {
			"types": "./client.d.ts",
			"import": "./client.js",
			"require": "./client.cjs"
		},
		"./parameters": {
			"types": "./parameters/index.d.ts",
			"import": "./parameters/index.js",
			"require": "./parameters/index.cjs"
		}
	},
	"publishConfig": {
		"provenance": true,
		"access": "public",
		"directory": "dist"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/RevoTale/next-navigation-utils.git"
	},
	"type": "module",
	"scripts": {
		"build": "rm -rf dist && tsup && tsc --emitDeclarationOnly --listEmittedFiles false && cp package.json README.md LICENSE dist/",
		"tsc": "tsc --noEmit",
		"changeset:version": "changeset version && git add --all",
		"changeset:publish": "changeset publish",
		"prepare": "pnpm build",
		"test": "pnpm lint && pnpm tsc && pnpm unit",
		"unit": "playwright test -x",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"bugs": {
		"url": "https://github.com/RevoTale/next-navigation-utils/issues"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@biomejs/biome": "^2.4.12",
		"@playwright/test": "^1.59.1",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"changeset": "^0.2.6",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"next": "^14.0 || ^15.0 || ^16.0.0",
		"react": "^18.0 || ^19.0"
	},
	"packageManager": "pnpm@10.33.4",
	"dependencies": {
		"use-debounce": "^10.1.1"
	}
}
